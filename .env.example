# Copy to .env.local (gitignored) and fill in your real values.
# In Vercel: install Neon from Marketplace and run `vercel env pull .env.local`.

# Neon Postgres (Vercel Marketplace auto-provisions these)
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_AT_LEAST_32_CHARS_OF_ENTROPY"
BETTER_AUTH_URL="http://localhost:3000"
